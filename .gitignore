# ============================
#  FICHIERS SYSTÈME
# ============================
Thumbs.db
.DS_Store
AppData/
*.log
*.tmp

# ============================
#  ENVIRONNEMENT / SÉCURITÉ
# ============================
.env
.env.*
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx

# ============================
#  BUILD / DÉPENDANCES
# ============================
node_modules/
dist/
build/
.cache/
.tmp/
*.map

# ============================
#  NETLIFY
# ============================
.netlify/
functions/node_modules/
functions/.cache/

# ============================
#  GITHUB ACTIONS / CI-CD
# ============================
# On ignore les fichiers générés automatiquement
.github/workflows/*.log
.github/workflows/*.tmp
.github/workflows/*-cache/

# ============================
#  ÉDITEURS / IDE
# ============================
.vscode/
.idea/
*.swp
*.swo

# ============================
#  ARCHIVES / EXPORTS
# ============================
*.zip
*.tar
*.gz
*.rar

# ============================
